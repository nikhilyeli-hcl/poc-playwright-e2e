{
  "name": "poc-playwright-e2e",
  "version": "1.0.0",
  "description": "POC for Playwright MCP and Playwright Agents with an Angular application",
  "scripts": {
    "start": "cd angular-app && npx ng serve",
    "build": "cd angular-app && npx ng build",
    "test:e2e": "npx playwright test",
    "test:e2e:ui": "npx playwright test --ui",
    "test:e2e:report": "npx playwright show-report",
    "test:unit": "cd angular-app && npx ng test --watch=false --browsers=ChromeHeadless"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nikhilyeli-hcl/poc-playwright-e2e.git"
  },
  "keywords": [
    "playwright",
    "mcp",
    "model-context-protocol",
    "angular",
    "e2e",
    "testing",
    "agents"
  ],
  "license": "MIT"
}
